# ════════════════════════════════════════════════════════════
#   KAVACH BACKEND — Environment Variables
#   इस file को .env नाम से save करें (backend/ folder में)
#   Git में NEVER commit करें — .gitignore में add करें
# ════════════════════════════════════════════════════════════

# ── Django Core ──────────────────────────────────────────────
# ✏️ EDIT: Generate करें:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=CHANGE_ME_GENERATE_A_REAL_SECRET_KEY

# ✏️ EDIT: Production में False रखें
DEBUG=False

# ✏️ EDIT: आपका server domain (comma separated)
ALLOWED_HOSTS=kavach.yourpolice.in,www.kavach.yourpolice.in

# ── Database (PostgreSQL) ─────────────────────────────────────
# ✏️ EDIT: PostgreSQL credentials
DB_NAME=kavach_db
DB_USER=kavach_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_HOST=localhost
DB_PORT=5432

# ── AWS S3 (Video Storage) ────────────────────────────────────
# ✏️ EDIT: AWS IAM user credentials (S3 + CloudFront access)
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_STORAGE_BUCKET=kavach-training-videos
AWS_REGION=ap-south-1

# ── CloudFront (CDN Signed URLs) ─────────────────────────────
# ✏️ EDIT: CloudFront distribution settings
CLOUDFRONT_DOMAIN=d1abc123xyz.cloudfront.net
CLOUDFRONT_KEY_ID=APKAEIBAERJR2EXAMPLE
# ✏️ EDIT: Path to your .pem private key file for CloudFront signing
CLOUDFRONT_PRIVATE_KEY_PATH=/etc/kavach/cloudfront_private_key.pem

# ── SMS Gateway (OTP delivery) ────────────────────────────────
# ✏️ EDIT: Your SMS provider API key (MSG91 / Fast2SMS / Twilio)
SMS_API_KEY=YOUR_SMS_GATEWAY_API_KEY_HERE
SMS_SENDER_ID=KAVACH

# ── CORS (Admin Dashboard) ────────────────────────────────────
# ✏️ EDIT: Your admin web dashboard URL
CORS_ALLOWED_ORIGINS=https://admin.kavach.yourpolice.in

# ── Redis (optional — for Celery background tasks) ────────────
# ✏️ EDIT: Redis server URL
REDIS_URL=redis://localhost:6379/0
